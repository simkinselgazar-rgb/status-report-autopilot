{
  "name": "status-report-autopilot",
  "version": "0.1.1",
  "description": "Self-hosted weekly client-report tool for digital agencies. Reads Asana / Linear / Slack / Zoom / Microsoft Teams, drafts a client-facing narrative in the agency's voice, and ships it as an email, a PDF, and a public read-only link.",
  "license": "Apache-2.0",
  "author": "Simkins & Elgazar AI Practice (ai.simkinselgazar.com)",
  "homepage": "https://github.com/simkinselgazar-rgb/status-report-autopilot",
  "repository": {
    "type": "git",
    "url": "https://github.com/simkinselgazar-rgb/status-report-autopilot.git"
  },
  "bugs": {
    "url": "https://github.com/simkinselgazar-rgb/status-report-autopilot/issues"
  },
  "keywords": [
    "status-report",
    "agency",
    "client-reporting",
    "mastra",
    "next.js",
    "self-hosted",
    "open-source"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/lib/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@mastra/core": "^1.34.0",
    "@mastra/memory": "^1.18.0",
    "@mastra/pg": "^1.10.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@react-pdf/renderer": "^4.5.1",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "next": "^16.0.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
