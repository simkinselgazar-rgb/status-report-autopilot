# ---------------------------------------------------------------------------
# Status Report Autopilot, environment configuration.
# Copy this file to .env and fill in the values you need.
# ---------------------------------------------------------------------------

# Database (REQUIRED). Postgres connection string for the product DB.
# When running through docker-compose this is supplied automatically; only
# set it yourself when running outside the container.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/status_report_autopilot

# Auth (REQUIRED). Better Auth signing secret for session cookies.
# Generate one with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL the app is reachable at. Used to build absolute /r/[token]
# report links inside outgoing emails. Defaults to http://localhost:3000.
# APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Email delivery (optional).
# Without these the dashboard still works: approving a report marks it sent
# and skips the email step. The shareable link and the PDF download keep
# working either way. Sign up at https://resend.com to get a key, then
# verify the sending domain in your Resend dashboard.
# ---------------------------------------------------------------------------

# RESEND_API_KEY=
# EMAIL_FROM="Your Agency <reports@yourdomain.com>"

# ---------------------------------------------------------------------------
# Recurring generation (optional).
# The app runs an hourly in-app scheduler in production. The
# /api/cron/generate-reports route is also available for ad-hoc force-runs
# and is guarded by this shared secret. Generate one with:
# openssl rand -hex 32. Without it the route refuses to run.
# ---------------------------------------------------------------------------

# CRON_SECRET=

# In development the scheduler is off by default. Set this to true to opt
# in. Note that a `next dev` restart will then fire connector pulls and an
# LLM call.
# SCHEDULER_ENABLED=false

# ---------------------------------------------------------------------------
# Dev model fallback (optional).
# Before you save a model in /settings, these env vars provide a working
# model so the agent can generate. Production deployments configure a
# model in the UI and leave these blank.
# ---------------------------------------------------------------------------

# Any OpenAI-compatible local endpoint (Ollama, LM Studio, vLLM, mlx).
# LOCAL_MODEL_URL=http://localhost:11434/v1
# LOCAL_MODEL_NAME=qwen2.5:32b-instruct-q4_K_M

# Or a Google AI Studio key for Gemini. Create one at:
# https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=

# ---------------------------------------------------------------------------
# Connector smoke test credentials (optional, dev-only).
# The running app never reads these, connector credentials are pasted in
# the onboarding wizard and stored on each client. They are only used by
# scripts/smoke-connector.ts, which exercises a single connector end to
# end against the real API for "does this actually work" checks. Fill in
# only the source you are about to test, then run:
#
#   npm exec tsx scripts/smoke-connector.ts -- --source=<asana|linear|slack|zoom|teams>
#
# Add --workspace=<id> to list its projects/channels/hosts, or
# --project=<id> (for Teams, --target=teamId|channelId) to fetch
# activity for the past 7 days.
# ---------------------------------------------------------------------------

# Asana Personal Access Token (My Settings → Apps → Manage developer
# apps). Asana PATs are full-account, Asana does not let you scope a
# PAT to read-only. Create one specifically for this app and revoke it
# when no longer used. The connector only reads.
# ASANA_TOKEN=

# Linear Personal API key (Settings → Security and access → Personal
# API keys, lin_api_…). Scope it to read-only when creating the key,
# the connector never writes.
# LINEAR_TOKEN=

# Slack Bot User OAuth Token (xoxb-…), with channels:read +
# channels:history + users:read scopes (all read-only). Invite the bot
# to channels you want to read.
# SLACK_TOKEN=

# Zoom Server-to-Server OAuth credentials (Zoom Marketplace → Build App
# → Server-to-Server OAuth). Scopes: user:read + cloud_recording:read,
# both read-only.
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# Microsoft Teams app-only credentials (Entra ID → App registrations).
# Application permissions: Team.ReadBasic.All + Channel.ReadBasic.All +
# ChannelMessage.Read.All, all read-only (grant admin consent).
# TEAMS_TENANT_ID=
# TEAMS_CLIENT_ID=
# TEAMS_CLIENT_SECRET=

# scripts/smoke-report.ts targets. Discover each id by running
# scripts/smoke-connector.ts for the source with --workspace=<id>, then copy
# the printed --project=<id> value into the matching env var below. A missing
# var skips that source (the script runs against the remaining sources).
# SRA_SMOKE_ASANA_PROJECT_GID=
# SRA_SMOKE_LINEAR_PROJECT_ID=
# SRA_SMOKE_SLACK_CHANNEL_ID=
# SRA_SMOKE_ZOOM_USER_ID=
# SRA_SMOKE_TEAMS_TARGET=
# SRA_SMOKE_CLIENT_NAME="Acme Studio"
